# BrainStorm — переменные окружения
# Скопируйте этот файл в .env и заполните значения

# Секретные ключи
SECRET_KEY=brainstorm-super-secret-key-change-me-in-production
ADMIN_SECRET_KEY=1777
CHEAT_TESTER_CODE=19112009

# GigaChat API (Сбер)
# Получить ключ: https://developers.sber.ru/studio/
# ВАЖНО: GIGACHAT_CREDENTIALS должен быть в формате base64!
# Формат: base64(client_id:client_secret)
# Пример: echo -n "your_client_id:your_client_secret" | base64
GIGACHAT_CREDENTIALS=YOUR_BASE64_CREDENTIALS_HERE
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Настройки сервера
PORT=5000
HOST=0.0.0.0
LOG_LEVEL=INFO
DEBUG=false
