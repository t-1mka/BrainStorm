# ══════════════════════════════════════════════
#   BrainStorm — шаблон настроек (.env.example)
#   Скопируй в .env и заполни своими данными
# ══════════════════════════════════════════════

# ── GigaChat (Сбербанк) ────────────────────────
# Получить ключ: https://developers.sber.ru/studio/
GIGACHAT_CREDENTIALS=ВСТАВЬ_СВОЙ_КЛЮЧ_СЮДА

# Scope: GIGACHAT_API_PERS (физ. лица) или GIGACHAT_API_CORP (юр. лица)
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# ── Сервер ────────────────────────────────────
SECRET_KEY=придумай-секретный-ключ-flask
HOST=0.0.0.0
PORT=5000
DEBUG=false
LOG_LEVEL=INFO

# ── Администрирование ─────────────────────────
# Секретный ключ для доступа к админ-панели (вводится в настройках)
ADMIN_SECRET_KEY=******
